@page "/trade-analytics"
@using EventLogs.Analytics.Models
@using EventLogs.Analytics.Services
@inject RegionalPaginationService PaginationService
@inject ILogger<TradeAnalytics> Logger
@inject IDialogService DialogService
@rendermode InteractiveServer

<PageTitle>Trade Analytics</PageTitle>

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="mt-4">
    <MudText Typo="Typo.h3" GutterBottom="true">Trade Analytics</MudText>
    <MudText Typo="Typo.body1" Class="mb-4">Parallel pagination across three regions with real-time metrics</MudText>

    <!-- Configuration Panel -->
    <MudPaper Class="pa-4 mb-4">
        <MudGrid>
            <MudItem xs="12" sm="3">
                <MudNumericField @bind-Value="pageSize" Label="Page Size" Min="1" Max="100000"
                    HelperText="Number of rows per page" Disabled="@isLoading" />
            </MudItem>
            <MudItem xs="12" sm="3">
                <MudNumericField @bind-Value="maxConcurrentTasks" Label="Concurrent Tasks Per Region" Min="1" Max="50"
                    HelperText="Max parallel queries per region" Disabled="@isLoading" />
            </MudItem>
            <MudItem xs="12" sm="3">
                <MudSelect T="string" @bind-Value="gatewayStrategy" Label="Gateway Strategy"
                    Variant="Variant.Outlined" Margin="Margin.Dense" Disabled="@isLoading"
                    HelperText="Compare multi-gateway vs single-gateway performance">
                    <MudSelectItem T="string" Value="@("multi")">Multi-Gateway (3 parallel)</MudSelectItem>
                    <MudSelectItem T="string" Value="@("us-east")">Single Gateway: us-east</MudSelectItem>
                    <MudSelectItem T="string" Value="@("us-central")">Single Gateway: us-central</MudSelectItem>
                    <MudSelectItem T="string" Value="@("us-west")">Single Gateway: us-west</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="3" Class="d-flex align-center">
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                    OnClick="LoadData" Disabled="@isLoading" FullWidth="true" Size="Size.Large">
                    @if (isLoading)
                    {
                        <MudProgressCircular Class="mr-2" Size="Size.Small" Indeterminate="true" />
                        <span>Loading...</span>
                    }
                    else
                    {
                        <span>Load Data</span>
                    }
                </MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <!-- Error Display -->
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <MudAlert Severity="Severity.Error" Class="mb-4">
            <strong>Error:</strong> @errorMessage
        </MudAlert>
    }

    <!-- Debug Info -->
    @if (!string.IsNullOrEmpty(debugMessage))
    {
        <MudAlert Severity="Severity.Info" Class="mb-4">
            <strong>Debug:</strong> @debugMessage
        </MudAlert>
    }

    <!-- Overall Progress -->
    @if (isLoading || globalMetrics != null)
    {
        <MudPaper Class="pa-4 mb-4">
            <MudText Typo="Typo.h6" GutterBottom="true">Overall Progress</MudText>
            <MudProgressLinear Color="Color.Primary" Size="Size.Large" Value="@(globalMetrics?.OverallProgress ?? 0)"
                Class="mb-2" Striped="@isLoading" />
            <MudText Typo="Typo.body2">@((globalMetrics?.OverallProgress ?? 0).ToString("F1"))% Complete</MudText>
        </MudPaper>
    }

    <!-- Regional Progress -->
    @if (globalMetrics != null && globalMetrics.RegionalMetrics.Any())
    {
        <MudPaper Class="pa-4 mb-4">
            <MudText Typo="Typo.h6" GutterBottom="true">Regional Progress</MudText>
            <MudGrid>
                @foreach (var kvp in globalMetrics.RegionalMetrics.OrderBy(x => x.Key))
                {
                    var metrics = kvp.Value;
                    <MudItem xs="12" md="4">
                        <MudCard>
                            <MudCardHeader>
                                <CardHeaderContent>
                                    <MudText Typo="Typo.h6">@kvp.Key.ToUpper()</MudText>
                                </CardHeaderContent>
                            </MudCardHeader>
                            <MudCardContent>
                                <MudProgressLinear Color="Color.Info" Value="@metrics.ProgressPercent" Class="mb-2" />
                                <MudText Typo="Typo.body2">@metrics.CompletedPages / @metrics.TotalPages pages</MudText>
                                <MudText Typo="Typo.caption">@metrics.TotalRowsProcessed rows processed</MudText>
                                @if (metrics.ElapsedTime.HasValue)
                                {
                                    <MudText Typo="Typo.caption">Elapsed: @metrics.ElapsedTime.Value.TotalSeconds.ToString("F1")s</MudText>
                                }
                            </MudCardContent>
                        </MudCard>
                    </MudItem>
                }
            </MudGrid>
        </MudPaper>

        <!-- Detailed Regional Metrics Table -->
        <MudPaper Class="pa-4 mb-4">
            <MudText Typo="Typo.h6" GutterBottom="true">Detailed Regional Performance</MudText>
            <MudTable Items="@globalMetrics.RegionalMetrics.OrderBy(x => x.Key)" Dense="true" Hover="true">
                <HeaderContent>
                    <MudTh>Region</MudTh>
                    <MudTh>Queries</MudTh>
                    <MudTh>Rows</MudTh>
                    <MudTh>Time (s)</MudTh>
                    <MudTh>Avg Query (ms)</MudTh>
                    <MudTh>QPS</MudTh>
                    <MudTh>Throughput (rows/s)</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Region">@context.Key.ToUpper()</MudTd>
                    <MudTd DataLabel="Queries">@context.Value.TotalQueries</MudTd>
                    <MudTd DataLabel="Rows">@context.Value.TotalRowsProcessed.ToString("N0")</MudTd>
                    <MudTd DataLabel="Time">
                        @if (context.Value.ElapsedTime.HasValue)
                        {
                            @context.Value.ElapsedTime.Value.TotalSeconds.ToString("F2")
                        }
                        else
                        {
                            <text>-</text>
                        }
                    </MudTd>
                    <MudTd DataLabel="Avg Query">@context.Value.AverageResponseTimeMs.ToString("F0")</MudTd>
                    <MudTd DataLabel="QPS">
                        @if (context.Value.ElapsedTime.HasValue && context.Value.ElapsedTime.Value.TotalSeconds > 0)
                        {
                            @((context.Value.TotalQueries / context.Value.ElapsedTime.Value.TotalSeconds).ToString("F1"))
                        }
                        else
                        {
                            <text>-</text>
                        }
                    </MudTd>
                    <MudTd DataLabel="Throughput">
                        @if (context.Value.ElapsedTime.HasValue && context.Value.ElapsedTime.Value.TotalSeconds > 0)
                        {
                            @((context.Value.TotalRowsProcessed / context.Value.ElapsedTime.Value.TotalSeconds).ToString("F0"))
                        }
                        else
                        {
                            <text>-</text>
                        }
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>
    }

    <!-- Metrics Dashboard -->
    @if (globalMetrics != null)
    {
        <MudPaper Class="pa-4 mb-4">
            <MudText Typo="Typo.h6" GutterBottom="true">Performance Metrics</MudText>
            <MudGrid>
                <MudItem xs="6" sm="4" md="2">
                    <MudCard Outlined="true" Style="background-color: var(--mud-palette-primary-lighten);">
                        <MudCardContent>
                            <MudText Typo="Typo.caption" Style="font-weight: bold;">Total Load Time</MudText>
                            <MudText Typo="Typo.h5" Style="color: var(--mud-palette-primary-darken);">
                                @if (globalMetrics.TotalElapsedTime.HasValue)
                                {
                                    @globalMetrics.TotalElapsedTime.Value.TotalSeconds.ToString("F2")<text>s</text>
                                }
                                else
                                {
                                    <text>-</text>
                                }
                            </MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                <MudItem xs="6" sm="4" md="2">
                    <MudCard Outlined="true">
                        <MudCardContent>
                            <MudText Typo="Typo.caption">Total Trades</MudText>
                            <MudText Typo="Typo.h5">@globalMetrics.TotalRowsProcessed.ToString("N0")</MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                <MudItem xs="6" sm="4" md="2">
                    <MudCard Outlined="true">
                        <MudCardContent>
                            <MudText Typo="Typo.caption">Total Queries</MudText>
                            <MudText Typo="Typo.h5">@globalMetrics.TotalQueries</MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                <MudItem xs="6" sm="4" md="2">
                    <MudCard Outlined="true">
                        <MudCardContent>
                            <MudText Typo="Typo.caption">Avg Query Time</MudText>
                            <MudText Typo="Typo.h5">@globalMetrics.AverageResponseTimeMs.ToString("F0")ms</MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                <MudItem xs="6" sm="4" md="2">
                    <MudCard Outlined="true" Style="background-color: var(--mud-palette-success-lighten);">
                        <MudCardContent>
                            <MudText Typo="Typo.caption" Style="font-weight: bold;">Throughput</MudText>
                            <MudText Typo="Typo.h5">
                                @if (globalMetrics.TotalElapsedTime.HasValue && globalMetrics.TotalElapsedTime.Value.TotalSeconds > 0)
                                {
                                    @((globalMetrics.TotalRowsProcessed / globalMetrics.TotalElapsedTime.Value.TotalSeconds).ToString("F0"))
                                    <text> rows/s</text>
                                }
                                else
                                {
                                    <text>-</text>
                                }
                            </MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                <MudItem xs="6" sm="4" md="2">
                    <MudCard Outlined="true" Style="background-color: var(--mud-palette-info-lighten);">
                        <MudCardContent>
                            <MudText Typo="Typo.caption" Style="font-weight: bold;">QPS</MudText>
                            <MudText Typo="Typo.h5">
                                @if (globalMetrics.TotalElapsedTime.HasValue && globalMetrics.TotalElapsedTime.Value.TotalSeconds > 0)
                                {
                                    @((globalMetrics.TotalQueries / globalMetrics.TotalElapsedTime.Value.TotalSeconds).ToString("F1"))
                                }
                                else
                                {
                                    <text>-</text>
                                }
                            </MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            </MudGrid>
        </MudPaper>
    }

    <!-- Chart -->
    @if (aggregatedData != null && aggregatedData.Any())
    {
        <MudPaper Class="pa-4 mb-4">
            <MudText Typo="Typo.h6" GutterBottom="true">Top 10 Symbols by Volume (BUY vs SELL)</MudText>
            <MudText Typo="Typo.caption" Class="mb-2">Click on a symbol to filter by symbol, or click legend chips to filter by side</MudText>
            <div style="position: relative;">
                <MudChart ChartType="ChartType.Bar"
                    T="double"
                    ChartSeries="@chartSeries"
                    SelectedIndex="selectedChartIndex"
                    SelectedIndexChanged="OnChartClicked"
                    XAxisLabels="@chartLabels"
                    Width="100%"
                    Height="450px"
                    ChartOptions="@chartOptions"
                    LegendPosition="Position.Bottom" />

                @* Display X-axis labels manually *@
                <div style="display: flex; justify-content: space-around; padding: 0 60px; margin-top: -20px;">
                    @foreach (var label in chartLabels)
                    {
                        <MudText Typo="Typo.body2" Style="text-align: center; font-weight: bold;">@label</MudText>
                    }
                </div>
            </div>

            <!-- Clickable Legend for BUY/SELL -->
            <MudText Typo="Typo.caption" Class="mt-4">
                <strong>Legend:</strong>
                <MudChip T="string" Size="Size.Small" Color="Color.Success" Class="ml-2"
                    OnClick="@(() => { filterSide = "BUY"; })">
                    BUY
                </MudChip>
                <MudChip T="string" Size="Size.Small" Color="Color.Error" Class="ml-2"
                    OnClick="@(() => { filterSide = "SELL"; })">
                    SELL
                </MudChip>
            </MudText>
        </MudPaper>

        <!-- Data Table -->
        <MudPaper Class="pa-4">
            <MudText Typo="Typo.h6" GutterBottom="true">Detailed Trade Data</MudText>

            <!-- Filters -->
            <MudGrid Class="mb-4">
                <MudItem xs="12" sm="3">
                    <MudSelect T="string" @bind-Value="filterSide" Label="Filter by Side"
                        Clearable="true" Variant="Variant.Outlined" Margin="Margin.Dense">
                        <MudSelectItem T="string" Value="@("")">All Sides</MudSelectItem>
                        @foreach (var side in GetUniqueSides())
                        {
                            <MudSelectItem T="string" Value="@side">@side</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="3">
                    <MudSelect T="string" @bind-Value="filterStatus" Label="Filter by Status"
                        Clearable="true" Variant="Variant.Outlined" Margin="Margin.Dense">
                        <MudSelectItem T="string" Value="@("")">All Statuses</MudSelectItem>
                        @foreach (var status in GetUniqueStatuses())
                        {
                            <MudSelectItem T="string" Value="@status">@status</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="3">
                    <MudSelect T="string" @bind-Value="filterSymbol" Label="Filter by Symbol"
                        Clearable="true" Variant="Variant.Outlined" Margin="Margin.Dense">
                        <MudSelectItem T="string" Value="@("")">All Symbols</MudSelectItem>
                        @foreach (var symbol in GetUniqueSymbols().Take(20))
                        {
                            <MudSelectItem T="string" Value="@symbol">@symbol</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="3">
                    <MudSelect T="string" @bind-Value="filterRegion" Label="Filter by Region"
                        Clearable="true" Variant="Variant.Outlined" Margin="Margin.Dense">
                        <MudSelectItem T="string" Value="@("")">All Regions</MudSelectItem>
                        @foreach (var region in GetUniqueRegions())
                        {
                            <MudSelectItem T="string" Value="@region">@region</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
            </MudGrid>

            <!-- Filter chips -->
            @if (!string.IsNullOrEmpty(filterSide) || !string.IsNullOrEmpty(filterStatus) || !string.IsNullOrEmpty(filterSymbol) || !string.IsNullOrEmpty(filterRegion))
            {
                <MudChipSet T="string" Class="mb-2">
                    @if (!string.IsNullOrEmpty(filterSide))
                    {
                        <MudChip T="string" Color="Color.Primary" OnClose="@(() => filterSide = "")">
                            Side: @filterSide
                        </MudChip>
                    }
                    @if (!string.IsNullOrEmpty(filterStatus))
                    {
                        <MudChip T="string" Color="Color.Secondary" OnClose="@(() => filterStatus = "")">
                            Status: @filterStatus
                        </MudChip>
                    }
                    @if (!string.IsNullOrEmpty(filterSymbol))
                    {
                        <MudChip T="string" Color="Color.Info" OnClose="@(() => filterSymbol = "")">
                            Symbol: @filterSymbol
                        </MudChip>
                    }
                    @if (!string.IsNullOrEmpty(filterRegion))
                    {
                        <MudChip T="string" Color="Color.Warning" OnClose="@(() => filterRegion = "")">
                            Region: @filterRegion
                        </MudChip>
                    }
                    <MudChip T="string" Color="Color.Default" OnClick="ClearFilters">Clear All</MudChip>
                </MudChipSet>
            }

            <MudTable Items="@GetFilteredData()" Hover="true" Striped="true" Dense="true" T="TradeAggregate">
                <HeaderContent>
                    <MudTh>Side</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh>Symbol</MudTh>
                    <MudTh>Region</MudTh>
                    <MudTh>Count</MudTh>
                    <MudTh>Total Quantity</MudTh>
                    <MudTh>Avg Price</MudTh>
                    <MudTh>Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Side">
                        <MudChip T="string" Size="Size.Small" Color="@GetSideColor(context.Side)">@context.Side</MudChip>
                    </MudTd>
                    <MudTd DataLabel="Status">
                        <MudBadge Color="@GetStatusColor(context.Status)" Overlap="true">@context.Status</MudBadge>
                    </MudTd>
                    <MudTd DataLabel="Symbol">@context.Symbol</MudTd>
                    <MudTd DataLabel="Region">@context.Region</MudTd>
                    <MudTd DataLabel="Count">@context.Count.ToString("N0")</MudTd>
                    <MudTd DataLabel="Total Quantity">@context.TotalQuantity.ToString("N2")</MudTd>
                    <MudTd DataLabel="Avg Price">@context.AveragePrice.ToString("C2")</MudTd>
                    <MudTd DataLabel="Actions">
                        <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Primary"
                            OnClick="@(() => ShowTradeDetails(context))">
                            View Details
                        </MudButton>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>
    }
</MudContainer>

@code {
    private int pageSize = 1000;
    private int maxConcurrentTasks = 5;
    private string gatewayStrategy = "multi";
    private bool isLoading = false;
    private string errorMessage = "";
    private string debugMessage = "";

    private List<TradeAggregate>? aggregatedData;
    private GlobalMetrics? globalMetrics;

    // Chart data
    private List<ChartSeries<double>> chartSeries = new();
    private string[] chartLabels = Array.Empty<string>();
    private ChartOptions chartOptions = new();
    private int selectedChartIndex = -1;

    // Filters
    private string filterSide = "";
    private string filterStatus = "";
    private string filterSymbol = "";
    private string filterRegion = "";

    private async Task LoadData()
    {
        Logger.LogInformation("LoadData button clicked - starting trade data fetch with pageSize={PageSize}, concurrentTasks={Tasks}",
            pageSize, maxConcurrentTasks);

        isLoading = true;
        errorMessage = "";
        debugMessage = $"Starting fetch: pageSize={pageSize}, concurrentTasks={maxConcurrentTasks}";
        aggregatedData = null;
        globalMetrics = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            Logger.LogInformation("Calling PaginationService.FetchTradeAggregatesAsync with strategy {Strategy}...",
                gatewayStrategy);
            debugMessage = $"Calling PaginationService with {gatewayStrategy} strategy...";
            await InvokeAsync(StateHasChanged);

            aggregatedData = await PaginationService.FetchTradeAggregatesAsync(
                pageSize,
                maxConcurrentTasks,
                onMetricsUpdate: (metrics) =>
                {
                    Logger.LogDebug("Metrics update received: {Progress}% complete", metrics.OverallProgress);
                    globalMetrics = metrics;
                    debugMessage = $"Progress: {metrics.OverallProgress:F1}%";
                    InvokeAsync(StateHasChanged);
                },
                gatewayStrategy: gatewayStrategy);

            Logger.LogInformation("Trade data fetch completed. Received {Count} aggregates", aggregatedData?.Count ?? 0);
            debugMessage = $"Fetch complete! Received {aggregatedData?.Count ?? 0} aggregates";

            // Prepare chart data
            PrepareChartData();

            isLoading = false;
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load trade data - Exception: {Message}", ex.Message);
            errorMessage = $"{ex.GetType().Name}: {ex.Message}";
            debugMessage = "";
            isLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void PrepareChartData()
    {
        if (aggregatedData == null || !aggregatedData.Any())
            return;

        // Group by symbol - take top 10 by volume
        var topSymbols = aggregatedData
            .GroupBy(a => a.Symbol)
            .OrderByDescending(g => g.Sum(a => a.Count))
            .Take(10)
            .Select(g => g.Key)
            .ToList();

        var grouped = aggregatedData
            .Where(a => topSymbols.Contains(a.Symbol))
            .GroupBy(a => a.Symbol)
            .OrderBy(g => g.Key)
            .ToList();

        chartLabels = grouped.Select(g => g.Key).ToArray();

        // Create series for BUY and SELL
        chartSeries = new List<ChartSeries<double>>
        {
            new ChartSeries<double>
            {
                Name = "BUY",
                Data = grouped.Select(g =>
                    (double)g.Where(a => a.Side == "BUY").Sum(a => a.Count)).ToArray()
            },
            new ChartSeries<double>
            {
                Name = "SELL",
                Data = grouped.Select(g =>
                    (double)g.Where(a => a.Side == "SELL").Sum(a => a.Count)).ToArray()
            }
        };

        chartOptions = new ChartOptions
        {
            ChartPalette = new[]
            {
                "#4CAF50", "#F44336", "#2196F3", "#FF9800", "#9C27B0",
                "#00BCD4", "#8BC34A", "#FF5722", "#673AB7", "#03A9F4"
            }
        };
    }

    private Color GetSideColor(string side)
    {
        return side.ToUpper() switch
        {
            "BUY" => Color.Success,
            "SELL" => Color.Error,
            _ => Color.Default
        };
    }

    private Color GetStatusColor(string status)
    {
        return status.ToUpper() switch
        {
            "PENDING" => Color.Default,
            "IN_PROGRESS" or "IN PROGRESS" => Color.Warning,
            "COMPLETE" or "COMPLETED" => Color.Success,
            "FAILED" or "ERROR" => Color.Error,
            _ => Color.Info
        };
    }

    private List<TradeAggregate> GetFilteredData()
    {
        if (aggregatedData == null) return new List<TradeAggregate>();

        return aggregatedData
            .Where(a => string.IsNullOrEmpty(filterSide) || a.Side == filterSide)
            .Where(a => string.IsNullOrEmpty(filterStatus) || a.Status == filterStatus)
            .Where(a => string.IsNullOrEmpty(filterSymbol) || a.Symbol == filterSymbol)
            .Where(a => string.IsNullOrEmpty(filterRegion) || a.Region == filterRegion)
            .ToList();
    }

    private List<string> GetUniqueSides()
    {
        if (aggregatedData == null) return new List<string>();
        return aggregatedData.Select(a => a.Side).Distinct().OrderBy(t => t).ToList();
    }

    private List<string> GetUniqueStatuses()
    {
        if (aggregatedData == null) return new List<string>();
        return aggregatedData.Select(a => a.Status).Distinct().OrderBy(s => s).ToList();
    }

    private List<string> GetUniqueSymbols()
    {
        if (aggregatedData == null) return new List<string>();
        return aggregatedData.Select(a => a.Symbol).Distinct().OrderBy(s => s).ToList();
    }

    private List<string> GetUniqueRegions()
    {
        if (aggregatedData == null) return new List<string>();
        return aggregatedData.Select(a => a.Region).Distinct().OrderBy(r => r).ToList();
    }

    private void ClearFilters()
    {
        filterSide = "";
        filterStatus = "";
        filterSymbol = "";
        filterRegion = "";
    }

    private void OnChartClicked(int index)
    {
        if (index >= 0 && chartSeries.Count > 0)
        {
            // MudChart returns flattened index by x-axis position, then by series
            // Index 0 = Symbol 0/Series 0 (AAPL/BUY), Index 1 = Symbol 0/Series 1 (AAPL/SELL)
            // Index 2 = Symbol 1/Series 0 (AMZN/BUY), Index 3 = Symbol 1/Series 1 (AMZN/SELL)
            int symbolIndex = index / chartSeries.Count;
            int seriesIndex = index % chartSeries.Count;

            if (symbolIndex < chartLabels.Length && seriesIndex < chartSeries.Count)
            {
                filterSymbol = chartLabels[symbolIndex];
                filterSide = chartSeries[seriesIndex].Name;
                selectedChartIndex = index;
                Logger.LogInformation("Chart clicked: filtering by symbol {Symbol} and side {Side}",
                    filterSymbol, filterSide);
            }
        }
    }

    private async Task ShowTradeDetails(TradeAggregate aggregate)
    {
        try
        {
            Logger.LogInformation("Fetching trade details for {Side}/{Status}/{Symbol}/{Region}",
                aggregate.Side, aggregate.Status, aggregate.Symbol, aggregate.Region);

            var details = await PaginationService.FetchTradeDetailsAsync(
                aggregate.Region,
                aggregate.Side,
                aggregate.Status,
                aggregate.Symbol,
                limit: 100);

            var parameters = new DialogParameters
            {
                ["Aggregate"] = aggregate,
                ["Details"] = details
            };

            var options = new DialogOptions
            {
                MaxWidth = MaxWidth.ExtraLarge,
                FullWidth = true,
                CloseButton = true
            };

            await DialogService.ShowAsync<TradeDetailsDialog>("Trade Details", parameters, options);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load trade details");
            errorMessage = $"Failed to load details: {ex.Message}";
        }
    }
}
