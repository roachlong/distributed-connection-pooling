apiVersion: cert-manager.io/v1
kind: Certificate
metadata:
  name: pgbouncer-server
  namespace: ${CRDB_NAMESPACE}
spec:
  secretName: pgbouncer-server
  duration: 8760h  # 1 year
  renewBefore: 720h  # 30 days
  issuerRef:
    name: vault-issuer
    kind: ClusterIssuer
  commonName: pgbouncer
  dnsNames:
    - pgbouncer
    - pgbouncer.${CRDB_NAMESPACE}
    - pgbouncer.${CRDB_NAMESPACE}.svc
    - pgbouncer.${CRDB_NAMESPACE}.svc.cluster.local
  usages:
    - server auth
    - client auth
